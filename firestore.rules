rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction helper pour vérifier si l'utilisateur est authentifié
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Fonction helper pour obtenir les données utilisateur
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Fonction helper pour vérifier l'appartenance à une organisation
    function belongsToOrg(orgId) {
      return isAuthenticated() && getUserData().organizationId == orgId;
    }

    // Organisations
    match /organizations/{orgId} {
      allow read: if belongsToOrg(orgId);
      allow create: if isAuthenticated();
      allow update: if belongsToOrg(orgId);
    }

    // Utilisateurs
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAuthenticated();
    }

    // Invitations
    match /invitations/{inviteId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Tests
    match /tests/{testId} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Autoriser update complet seulement si pas de submissions (submissionCount == 0)
      // OU si c'est juste une incrémentation du submissionCount (pour les soumissions de candidats)
      allow update: if (isAuthenticated() && belongsToOrg(resource.data.organizationId) && resource.data.submissionCount == 0)
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['submissionCount']));
      allow delete: if isAuthenticated() && belongsToOrg(resource.data.organizationId);
    }

    // Submissions
    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAuthenticated();
    }

    // Training Paths (Parcours de formation)
    match /trainingPaths/{pathId} {
      // Lecture publique: nécessaire pour que les candidats non-authentifiés puissent
      // trouver leur parcours via checkTrainingPath() lors du passage du test
      allow read: if true;
      allow create: if isAuthenticated();
      // Update autorisé si: membre de l'org OU candidat qui met à jour uniquement sessions/status
      allow update: if (isAuthenticated() && belongsToOrg(resource.data.organizationId))
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sessions', 'status']);
      allow delete: if isAuthenticated() && belongsToOrg(resource.data.organizationId);
    }
  }
}
